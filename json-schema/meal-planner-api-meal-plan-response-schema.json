{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MealPlanResponse",
  "description": "MealPlanResponse schema from Edamam Meal Planner API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/edamam/refs/heads/main/json-schema/meal-planner-api-meal-plan-response-schema.json",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "example": "OK"
    },
    "selection": {
      "type": "array",
      "description": "One entry per day, each containing selected sections.",
      "items": {
        "type": "object",
        "properties": {
          "sections": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "_links": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    }
  }
}
