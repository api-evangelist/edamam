        {
          "id": "ec60f555-2130-4b82-adc2-1a01531c936b",
          "name": "Edamam Analyze Single Ingredient Line",
          "request": {
            "name": "Edamam Analyze Single Ingredient Line",
            "description": {
              "content": "Analyze a single natural-language ingredient line (for example `1 cup of rice`) and receive per-ingredient nutrition data including calories, total weight, and the full nutrient breakdown.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api",
                "nutrition-data"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "app_id",
                  "value": "<string>",
                  "description": "(Required) Application identifier from the Edamam developer dashboard."
                },
                {
                  "disabled": false,
                  "key": "app_key",
                  "value": "<string>",
                  "description": "(Required) Application key from the Edamam developer dashboard."
                },
                {
                  "disabled": false,
                  "key": "ingr",
                  "value": "<string>",
                  "description": "(Required) Ingredient text to analyze, e.g. `1 cup of rice`."
                },
                {
                  "disabled": false,
                  "key": "nutrition-type",
                  "value": "cooking",
                  "description": "Whether to apply cooking or logging nutrient profiles."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "disabled": false,
                "description": "Active user identifier for tracking.",
                "key": "Edamam-Account-User",
                "value": "<string>"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
