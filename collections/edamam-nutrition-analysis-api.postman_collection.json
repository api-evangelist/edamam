      "id": "8ab0e229-d0d1-47be-af22-622e186872f9",
      "name": "Nutrition Analysis",
      "description": {
        "content": "Analyze recipes and ingredient lines for nutrition content.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "451fe746-a9f2-4f81-9d90-5b51e140499a",
          "name": "Edamam Analyze Full Recipe Nutrition",
          "request": {
            "name": "Edamam Analyze Full Recipe Nutrition",
            "description": {
              "content": "Submit a full recipe (title, ingredient lines, yield, and optional source URL) and receive a comprehensive nutrition analysis including calories, total weight, diet and health labels, cautions, and a full breakdown of macro- and micronutrients.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api",
                "nutrition-details"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "app_id",
                  "value": "<string>",
                  "description": "(Required) Application identifier from the Edamam developer dashboard."
                },
                {
                  "disabled": false,
                  "key": "app_key",
                  "value": "<string>",
                  "description": "(Required) Application key from the Edamam developer dashboard."
                },
                {
                  "disabled": false,
                  "key": "force",
                  "value": "<boolean>",
                  "description": "Force re-evaluation even if a cached result exists."
                },
                {
                  "disabled": false,
                  "key": "beta",
                  "value": "<boolean>",
                  "description": "Enable recipe classification beta features."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "disabled": false,
                "description": "Active user identifier for tracking.",
                "key": "Edamam-Account-User",
                "value": "<string>"
              },
              {
                "disabled": false,
                "description": "Language of the submitted recipe text.",
                "key": "Content-Language",
                "value": "<string>"
              },
              {
                "disabled": false,
                "description": "ETag for caching previously analyzed recipes.",
                "key": "If-None-Match",
                "value": "<string>"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ingr\": [\n    \"<string>\",\n    \"<string>\"\n  ],\n  \"title\": \"<string>\",\n  \"prep\": \"<string>\",\n  \"yield\": \"<string>\",\n  \"url\": \"<uri>\",\n  \"summary\": \"<string>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
