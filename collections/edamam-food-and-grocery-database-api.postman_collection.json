          "name": "Edamam Resolve Nutrients for Selected Foods",
          "request": {
            "name": "Edamam Resolve Nutrients for Selected Foods",
            "description": {
              "content": "Retrieve the full nutrient breakdown for one or more foods at specific quantities and measures, using the `foodId` and `measureURI` values returned by the parser endpoint.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api",
                "food-database",
                "v2",
                "nutrients"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "app_id",
                  "value": "<string>",
                  "description": "(Required) Application identifier from the Edamam developer dashboard."
                },
                {
                  "disabled": false,
                  "key": "app_key",
                  "value": "<string>",
                  "description": "(Required) Application key from the Edamam developer dashboard."
