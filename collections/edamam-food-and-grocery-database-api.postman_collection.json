      "item": [
        {
          "id": "8eb83e48-3fcb-4e38-b371-b84ebd38401c",
          "name": "Edamam Search Foods by Keyword or Barcode",
          "request": {
            "name": "Edamam Search Foods by Keyword or Barcode",
            "description": {
              "content": "Search the food and grocery database by keyword, food name, or UPC/EAN barcode. Returns a parsed top match plus a ranked list of hints, each including the food record and its available measures and qualifiers.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api",
                "food-database",
                "v2",
                "parser"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "app_id",
                  "value": "<string>",
                  "description": "(Required) Application identifier from the Edamam developer dashboard."
                },
                {
                  "disabled": false,
                  "key": "app_key",
                  "value": "<string>",
                  "description": "(Required) Application key from the Edamam developer dashboard."
                },
                {
                  "disabled": false,
                  "key": "ingr",
                  "value": "<string>",
                  "description": "Food keyword or name to search for."
                },
                {
                  "disabled": false,
                  "key": "upc",
                  "value": "<string>",
                  "description": "UPC/EAN barcode to look up."
                },
                {
                  "disabled": false,
                  "key": "category",
                  "value": "<string>",
                  "description": "Filter results by food category."
                },
                {
                  "disabled": false,
                  "key": "categoryLabel",
                  "value": "<string>",
                  "description": "Broader category filter."
                },
                {
                  "disabled": false,
                  "key": "nutrition-type",
                  "value": "<string>",
                  "description": "Nutrient profile to apply to returned foods."
                },
                {
                  "disabled": false,
                  "key": "health",
                  "value": "<string>",
                  "description": "Health label filter (repeatable)."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "disabled": false,
                "description": "Active user identifier for tracking (required when account tracking is enabled).",
                "key": "Edamam-Account-User",
                "value": "<string>"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
