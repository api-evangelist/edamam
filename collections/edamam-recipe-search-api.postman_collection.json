    {
      "id": "1cf9242a-2f6f-4977-a308-6cd14a2fb651",
      "name": "Recipe Search",
      "description": {
        "content": "Search recipes and retrieve recipe records by URI.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "44bd3af4-000e-47ec-b0c1-fa6f08b270e0",
          "name": "Edamam Search Recipes",
          "request": {
            "name": "Edamam Search Recipes",
            "description": {
              "content": "Search the recipe database by keyword with rich filtering on diet, health, cuisine type, meal type, dish type, calorie range, and preparation time. Returns a paginated set of recipe hits with full nutrition analysis and source attribution.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api",
                "recipes",
                "v2"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "type",
                  "value": "public",
                  "description": "(Required) Recipe access type. Use `public` for the public recipe pool."
                },
                {
                  "disabled": false,
                  "key": "app_id",
                  "value": "<string>",
                  "description": "(Required) Application identifier from the Edamam developer dashboard."
                },
                {
                  "disabled": false,
                  "key": "app_key",
                  "value": "<string>",
                  "description": "(Required) Application key from the Edamam developer dashboard."
                },
                {
                  "disabled": false,
                  "key": "q",
                  "value": "<string>",
                  "description": "Free-text search query, e.g. `chicken`."
                },
                {
                  "disabled": false,
                  "key": "diet",
                  "value": "<string>",
                  "description": "Diet label filter (repeatable)."
                },
                {
                  "disabled": false,
                  "key": "health",
                  "value": "<string>",
                  "description": "Health label filter (repeatable), e.g. `vegan`, `gluten-free`."
                },
                {
                  "disabled": false,
                  "key": "cuisineType",
                  "value": "<string>",
                  "description": "Cuisine type filter (repeatable), e.g. `Italian`."
                },
                {
                  "disabled": false,
                  "key": "mealType",
                  "value": "<string>",
                  "description": "Meal type filter (repeatable), e.g. `Breakfast`."
                },
                {
                  "disabled": false,
                  "key": "dishType",
                  "value": "<string>",
                  "description": "Dish type filter (repeatable), e.g. `Main course`."
                },
                {
                  "disabled": false,
                  "key": "calories",
                  "value": "<string>",
                  "description": "Calorie range filter, e.g. `100-300`."
                },
                {
                  "disabled": false,
                  "key": "time",
                  "value": "<string>",
                  "description": "Preparation time range in minutes, e.g. `1-60`."
                },
                {
                  "disabled": false,
                  "key": "imageSize",
                  "value": "<string>",
                  "description": "Requested image resolution."
                },
                {
                  "disabled": false,
                  "key": "co2EmissionsClass",
                  "value": "<string>",
                  "description": "Carbon footprint rating filter (requires beta=true)."
                },
                {
                  "disabled": false,
                  "key": "beta",
                  "value": "<boolean>",
                  "description": "Enable beta features such as CO2 emissions filtering."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "disabled": false,
                "description": "Active user identifier for tracking.",
                "key": "Edamam-Account-User",
                "value": "<string>"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
